---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { filterPublishedPosts } from '../../../lib/publishedNews';
import { formatNewsDate } from '../../../lib/newsDate';
import { t } from '../../../i18n';
import '../../../styles/global.css';

export async function getStaticPaths() {
  const posts = filterPublishedPosts(await getCollection('tinTuc'));
  return posts
    .filter((p) => p.data.lang === 'vi')
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const m = t('vi');
const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  canonicalPath={`/vi/tin-tuc/${post.id}`}
>
  <Header slot="header" />
  <section class="section">
    <div class="container prose">
      <p><a href="/vi/tin-tuc">{m.news.back}</a></p>
      <h1>{post.data.title}</h1>
      <p class="news-meta">{formatNewsDate(post.data.pubDate)}</p>
      <Content />
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>
