---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PlatformHero from '../../components/platform/PlatformHero.astro';
import EcosystemSection from '../../components/platform/EcosystemSection.astro';
import WhyNovixaSection from '../../components/platform/WhyNovixaSection.astro';
import HealthcareJourney from '../../components/platform/HealthcareJourney.astro';
import ClinicSection from '../../components/platform/ClinicSection.astro';
import PartnersStrip from '../../components/platform/PartnersStrip.astro';
import PlatformCta from '../../components/platform/PlatformCta.astro';
import { t } from '../../i18n';
import { buildSiteGraphStructuredData } from '../../lib/site-structured-data';
import '../../styles/global.css';
import '../../styles/platform-home.css';

const m = t('vi');
const jsonLd = buildSiteGraphStructuredData();
---

<BaseLayout
  title={m.meta.siteName}
  description={m.meta.description}
  canonicalPath="/vi/"
  jsonLd={jsonLd}
>
  <Header slot="header" />

  <div class="home-page">
    <PlatformHero />
    <EcosystemSection />
    <WhyNovixaSection />
    <HealthcareJourney />
    <ClinicSection />
    <PlatformCta />
    <PartnersStrip />
  </div>

  <Footer slot="footer" />
</BaseLayout>
