---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import AssessmentSection from '../../components/AssessmentSection.astro';
import BenefitsSection from '../../components/BenefitsSection.astro';
import DashboardSection from '../../components/DashboardSection.astro';
import SolutionSection from '../../components/SolutionSection.astro';
import CustomerAppSection from '../../components/CustomerAppSection.astro';
import AISection from '../../components/AISection.astro';
import PricingSection from '../../components/PricingSection.astro';
import FaqSection from '../../components/FaqSection.astro';
import CTASection from '../../components/CTASection.astro';
import { t } from '../../i18n';
import '../../styles/global.css';

const m = t('vi');
---

<BaseLayout
  title={m.meta.siteName}
  description={m.meta.description}
  canonicalPath="/vi"
>
  <Header slot="header" />
  <div class="home-fold">
    <div class="container home-fold-inner">
      <Hero />
      <AssessmentSection />
    </div>
  </div>
  <BenefitsSection />
  <DashboardSection />
  <SolutionSection />
  <CustomerAppSection />
  <AISection />
  <PricingSection />
  <FaqSection />
  <CTASection />
  <Footer slot="footer" />
</BaseLayout>
