---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { NEWS_CATEGORIES, newsCategoryPath } from '../../../lib/news-categories';
import { filterPublishedPosts } from '../../../lib/publishedNews';
import '../../../styles/global.css';

const published = filterPublishedPosts(await getCollection('tinTuc'));
const counts = Object.fromEntries(
  NEWS_CATEGORIES.map((c) => [
    c.id,
    published.filter((p) => (p.data.category ?? 'tin-tuc-novixa') === c.id).length,
  ]),
);
---

<BaseLayout
  title="Kiến thức nhà thuốc"
  description="Kiến thức quản trị, vận hành, bán hàng, AI, Academy và tin tức Novixa dành cho nhà thuốc."
  canonicalPath="/vi/kien-thuc/"
>
  <Header slot="header" />
  <section class="section">
    <div class="container">
      <h1 class="section-title">Kiến thức nhà thuốc</h1>
      <p class="section-intro">
        Kho nội dung theo nhóm chủ đề — chọn mục bên dưới để xem bài viết.
      </p>
      <ul class="knowledge-hub-grid">
        {
          NEWS_CATEGORIES.map((cat) => (
            <li>
              <a class="knowledge-hub-card" href={newsCategoryPath(cat.id)}>
                <span class="knowledge-hub-card__title">{cat.label}</span>
                <span class="knowledge-hub-card__desc">{cat.description}</span>
                <span class="knowledge-hub-card__meta">{counts[cat.id] ?? 0} bài</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>

<style>
  .knowledge-hub-grid {
    list-style: none;
    margin: 1.75rem 0 0;
    padding: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  }

  .knowledge-hub-card {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    height: 100%;
    padding: 1.15rem 1.2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface, #fff);
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .knowledge-hub-card:hover {
    border-color: var(--color-primary, #1a7a4c);
    transform: translateY(-1px);
  }

  .knowledge-hub-card__title {
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--color-primary, #1a7a4c);
  }

  .knowledge-hub-card__desc {
    font-size: 0.92rem;
    line-height: 1.45;
    color: var(--color-muted, #5b6b7c);
    flex: 1;
  }

  .knowledge-hub-card__meta {
    font-size: 0.8rem;
    color: var(--color-muted, #5b6b7c);
  }
</style>
