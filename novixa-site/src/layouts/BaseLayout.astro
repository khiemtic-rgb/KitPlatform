---
import '../styles/global.css';
import { t, type Locale } from '../i18n';
import { absoluteUrl, DEFAULT_OG_IMAGE, SITE_NAME, SITE_URL } from '../lib/site';

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
  image?: string;
  canonicalPath?: string;
  type?: 'website' | 'article';
}

const { title, description, locale = 'vi', image, canonicalPath, type = 'website' } = Astro.props;
const m = t(locale);
const pageDescription = description ?? m.meta.description;
const fullTitle = title === m.meta.siteName ? `${title} — ${m.meta.tagline}` : `${title} — ${m.meta.siteName}`;
const ogImage = absoluteUrl(image ?? DEFAULT_OG_IMAGE);
const canonical = canonicalPath ? absoluteUrl(canonicalPath) : new URL(Astro.url.pathname, SITE_URL).href;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={m.meta.keywords} />
    <meta name="author" content={SITE_NAME} />
    <meta name="theme-color" content="#0F4C81" />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <title>{fullTitle}</title>

    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={`${SITE_NAME} — ${m.meta.tagline}`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <slot name="header" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
