---
import { t } from '../i18n';

const m = t('vi');
const base = '/vi';
const path = Astro.url.pathname;

const links = [
  { href: `${base}#giai-phap`, label: m.nav.platform, dropdown: true },
  { href: `${base}#giai-phap`, label: m.nav.solutions, dropdown: true },
  { href: `${base}#danh-gia`, label: m.nav.customers },
  { href: `${base}/tin-tuc`, label: m.nav.news, active: path.startsWith(`${base}/tin-tuc`) },
  { href: `${base}/ve-chung-toi`, label: m.nav.about, active: path.startsWith(`${base}/ve-chung-toi`) },
];
---

<header class="site-header" data-site-header>
  <div class="container header-inner">
    <a href={base} class="logo">
      <span class="logo-crop" aria-hidden="true">
        <img class="logo-img" src="/images/logo.png" alt="" width="160" height="160" decoding="async" />
      </span>
      <span class="logo-stack">
        <span class="logo-text">NOVIXA</span>
        <span class="logo-tagline">Quản trị nhà thuốc thông minh</span>
      </span>
    </a>

    <button
      type="button"
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="site-nav"
      data-nav-toggle
    >
      <span class="sr-only">{m.nav.menuOpen}</span>
      <span class="nav-toggle-bar" aria-hidden="true"></span>
      <span class="nav-toggle-bar" aria-hidden="true"></span>
      <span class="nav-toggle-bar" aria-hidden="true"></span>
    </button>

    <nav id="site-nav" class="nav" data-nav aria-label="Menu chính">
      {
        links.map((link) => (
          <a href={link.href} class:list={{ active: link.active }}>
            {link.label}
            {link.dropdown && <span class="nav-chevron" aria-hidden="true">▾</span>}
          </a>
        ))
      }
    </nav>

    <div class="nav-actions">
      <a
        href="/vi/health-check"
        class:list={['nav-health-check', { active: path.startsWith(`${base}/health-check`) }]}
      >
        <span class="nav-health-check__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
            <path d="M9 5a3 3 0 00-3 3v1a2 2 0 01-2 2 2 2 0 000 4 2 2 0 012 2v1a3 3 0 003 3" />
            <path d="M15 5a3 3 0 013 3v1a2 2 0 012 2 2 2 0 010 4 2 2 0 01-2 2v1a3 3 0 01-3 3" />
          </svg>
        </span>
        <span class="nav-health-check__label">AI HEALTH CHECK</span>
      </a>
      <a href="https://app.novixa.vn" class="nav-login">{m.nav.login}</a>
      <a href="/vi/lien-he" class="nav-cta">{m.nav.demo}</a>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector('[data-site-header]');
  const toggle = document.querySelector('[data-nav-toggle]');
  const nav = document.querySelector('[data-nav]');

  const syncHeader = () => {
    header?.classList.toggle('is-scrolled', window.scrollY > 12);
  };

  const syncNavOpen = () => {
    header?.classList.toggle('nav-open', nav?.classList.contains('is-open') ?? false);
  };

  syncHeader();
  window.addEventListener('scroll', syncHeader, { passive: true });

  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    syncNavOpen();
  });

  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      nav.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      syncNavOpen();
    });
  });
</script>
