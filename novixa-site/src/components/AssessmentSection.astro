---
const steps = [
  { title: '15 phút', desc: 'Hoàn thành đánh giá' },
  { title: '30 câu hỏi', desc: 'Toàn diện & nhanh' },
  { title: 'AI phân tích', desc: 'Chấm điểm tự động' },
  { title: 'PDF', desc: 'Báo cáo chi tiết' },
  { title: 'Tư vấn', desc: 'Cùng chuyên gia' },
];

const assessmentUrl = 'https://survey.novixa.vn';
---

<section class="assessment-section assessment-fold" id="danh-gia">
  <div class="assessment-fold-card">
    <div class="assessment-fold-head">
      <span class="assessment-fold-badge" aria-hidden="true">🏥</span>
      <div>
        <p class="assessment-fold-label">AI Health Check</p>
        <h2>Nhà thuốc của bạn đang gặp vấn đề ở đâu?</h2>
      </div>
    </div>

    <div class="assessment-fold-flow" aria-label="Quy trình đánh giá miễn phí">
      {
        steps.map((step, i) => (
          <div class="assessment-fold-step-wrap">
            <div class="assessment-fold-step">
              <strong>{step.title}</strong>
              <span>{step.desc}</span>
            </div>
            {i < steps.length - 1 && <span class="assessment-fold-arrow" aria-hidden="true">→</span>}
          </div>
        ))
      }
    </div>

    <a class="btn btn-green btn-xl assessment-fold-cta" href={assessmentUrl}>
      Bắt đầu đánh giá ngay
    </a>
  </div>
</section>
