---
import { t } from '../i18n';

const m = t('vi');
const c = m.contact;
const year = new Date().getFullYear();
const hasFacebook = Boolean(c.facebookUrl?.trim());
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p><strong>{m.meta.siteName}</strong> — {m.meta.tagline}</p>
    {
      hasFacebook && (
        <p>
          <a class="footer-link" href={c.facebookUrl} target="_blank" rel="noopener noreferrer">
            {c.facebookPageName || c.facebookLabel}
          </a>
        </p>
      )
    }
    <p class="muted">{m.footer.erpNote}</p>
    <p class="muted">© {year} {m.footer.rights}</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-text);
    color: #cbd5e1;
    padding: 2.5rem 0;
    margin-top: 3rem;
    font-size: 0.9rem;
  }
  .footer-inner p {
    margin: 0.35rem 0;
  }
  .footer-link {
    color: #93c5fd;
  }
  .footer-link:hover {
    color: #fff;
  }
  .muted {
    color: #94a3b8;
    font-size: 0.85rem;
  }
</style>
