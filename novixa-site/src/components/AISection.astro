---
const aiCards = [
  { title: 'Dự báo nhập hàng', text: 'Ước tính nhu cầu nhập hàng.' },
  { title: 'Gợi ý bán FEFO', text: 'Ưu tiên xuất kho thông minh.' },
  { title: 'Phân tích doanh thu', text: 'Theo dõi hiệu quả kinh doanh.' },
  { title: 'Phát hiện bất thường', text: 'Cảnh báo lệch dữ liệu vận hành.' },
];
---

<section class="section ai-section" id="ai">
  <div class="container ai-grid">
    <div class="section-heading">
      <p class="eyebrow">AI</p>
      <h2>AI đồng hành cùng nhà thuốc.</h2>
      <p>
        Không thay thế con người. Giúp con người ra quyết định nhanh hơn.
      </p>
      <a class="btn btn-light ai-cta" href="/vi/lien-he">Tìm hiểu về AI</a>
    </div>

    <div class="ai-card-grid">
      {
        aiCards.map((card) => (
          <article class="ai-card">
            <span></span>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
