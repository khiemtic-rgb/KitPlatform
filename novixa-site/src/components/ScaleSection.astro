---
const highlights = [
  {
    icon: '🚀',
    title: 'Khởi đầu đơn giản',
    text: 'Triển khai nhanh, dễ làm quen và sẵn sàng đưa vào vận hành.',
  },
  {
    icon: '📈',
    title: 'Mở rộng theo doanh nghiệp',
    text: 'Từ một nhà thuốc đến hệ thống nhiều chi nhánh trên cùng một nền tảng.',
  },
  {
    icon: '🔄',
    title: 'Dữ liệu đồng bộ',
    text: 'Bán hàng, tồn kho, khách hàng và báo cáo luôn được kết nối.',
  },
  {
    icon: '📊',
    title: 'Ra quyết định bằng dữ liệu',
    text: 'Dashboard thời gian thực giúp theo dõi và phân tích hoạt động kinh doanh.',
  },
  {
    icon: '🤖',
    title: 'Công nghệ sẵn sàng cho AI',
    text: 'Nền tảng được thiết kế để từng bước ứng dụng AI vào phân tích và hỗ trợ vận hành.',
  },
  {
    icon: '🔗',
    title: 'Hệ sinh thái mở',
    text: 'Kiến trúc linh hoạt, sẵn sàng tích hợp với các dịch vụ và thiết bị trong tương lai.',
  },
];
---

<section class="section enterprise-section" id="enterprise-saas">
  <div class="container">
    <div class="section-heading center enterprise-heading">
      <p class="eyebrow">Enterprise SaaS</p>
      <h2>Vì sao Novixa là nền tảng để phát triển lâu dài?</h2>
      <p>
        Không chỉ giải quyết bài toán hôm nay, Novixa được thiết kế để đồng hành cùng sự phát triển
        của nhà thuốc trong nhiều năm tới.
      </p>
    </div>

    <div class="enterprise-grid">
      {
        highlights.map((item) => (
          <article class="enterprise-card">
            <span class="enterprise-icon" aria-hidden="true">{item.icon}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
