---
---

<section class="ph-hero" id="platform" aria-labelledby="ph-hero-title">
  <div class="ph-hero__bg" aria-hidden="true"></div>
  <div class="container ph-hero__grid">
    <div class="ph-hero__copy">
      <h1 id="ph-hero-title" class="ph-hero__title">
        <span class="ph-hero__brand">NOVIXA</span> Healthcare Platform
      </h1>
      <p class="ph-hero__lead">
        Kết nối và vận hành hệ sinh thái
        <strong>Nhà thuốc</strong>
        <span aria-hidden="true">•</span>
        <strong>Bệnh nhân</strong>
        <span aria-hidden="true">•</span>
        <strong>Phòng khám</strong>
      </p>
      <p class="ph-hero__sub">
        Nền tảng thống nhất giúp quản trị vận hành, chăm sóc khách hàng và kết nối dịch vụ
        y tế thông minh trên cùng một hệ thống.
      </p>
      <div class="ph-hero__actions">
        <a class="ph-btn ph-btn--primary" href="/vi/lien-he/">Đăng ký Demo</a>
        <a class="ph-btn ph-btn--ghost" href="/vi/danh-gia/">
          <span class="ph-btn__ico" aria-hidden="true">✦</span>
          AI Health Check
        </a>
      </div>
    </div>

    <div class="ph-hero__visual">
      <img
        class="ph-hero__shot"
        src="/images/hero/home-devices.png"
        alt="Novixa trên laptop và điện thoại — kết nối nhà thuốc, bệnh nhân và phòng khám"
        width="1400"
        height="1000"
        loading="eager"
        decoding="async"
      />
    </div>
  </div>
</section>
