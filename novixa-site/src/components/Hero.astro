---
import DashboardPreview from './DashboardPreview.astro';

const assessmentUrl = 'https://survey.novixa.vn';

const heroTrust = [
  { label: '15 phút', icon: 'clock' },
  { label: '30 câu hỏi', icon: 'questions' },
  { label: 'Báo cáo PDF', icon: 'pdf' },
];
---

<section class="hero" id="hero">
  <div class="hero-grid">
    <div class="hero-content motion-in">
      <h1>
        Vận hành nhà thuốc<br />
        <span>thông minh hơn</span><br />
        mỗi ngày.
      </h1>
      <p class="hero-lead">
        Novixa giúp bạn kiểm soát tồn kho, tăng doanh thu, giữ chân khách hàng
        và vận hành nhà thuốc hiệu quả hơn trên một nền tảng duy nhất.
      </p>
      <div class="hero-actions">
        <a class="btn btn-green btn-lg" href={assessmentUrl}>Đánh giá miễn phí</a>
        <a class="btn btn-demo btn-lg" href="/vi/lien-he">Đăng ký Demo</a>
      </div>

      <a class="hero-pitch-card" href={assessmentUrl}>
        <span class="hero-pitch-icon" aria-hidden="true">🎯</span>
        <div class="hero-pitch-body">
          <strong>Đánh giá mức độ trưởng thành quản trị nhà thuốc</strong>
          <span class="hero-pitch-meta">
            {
              heroTrust.map((item, i) => (
                <>
                  {i > 0 && <span class="hero-pitch-dot">·</span>}
                  <span>{item.label}</span>
                </>
              ))
            }
          </span>
        </div>
        <span class="hero-pitch-cta">Bắt đầu miễn phí</span>
      </a>
    </div>

    <div class="hero-visual motion-in motion-delay">
      <div class="hero-mockup-wrap" aria-label="Dashboard Novixa">
        <DashboardPreview compact variant="hero" />
      </div>
    </div>
  </div>
</section>
