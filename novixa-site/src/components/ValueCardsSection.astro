---
const cards = [
  { icon: 'clock', title: '7 phút', desc: 'Hoàn thành đánh giá' },
  { icon: 'clipboard', title: '30 câu hỏi', desc: 'Đánh giá toàn diện' },
  { icon: 'message', title: 'Tư vấn miễn phí', desc: 'Cùng chuyên gia Novixa' },
];
---

<section class="hp-trust" aria-label="Thông tin đánh giá nhanh">
  <div class="container">
    <div class="hp-trust__bar">
      {
        cards.map((card, i) => (
          <>
            {i > 0 && <span class="hp-trust__divider" aria-hidden="true" />}
            <article class="hp-trust__item">
              <span class="hp-trust__icon" aria-hidden="true">
                {card.icon === 'clock' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                    <circle cx="12" cy="12" r="9" />
                    <path d="M12 7v5l3 2" />
                  </svg>
                )}
                {card.icon === 'clipboard' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                    <rect x="5" y="4" width="14" height="17" rx="2" />
                    <path d="M9 4V3a1 1 0 011-1h4a1 1 0 011 1v1" />
                    <path d="M9 10h6M9 14h4" />
                  </svg>
                )}
                {card.icon === 'message' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                    <path d="M4 6a2 2 0 012-2h12a2 2 0 012 2v8a2 2 0 01-2 2h-5l-4 4v-4H6a2 2 0 01-2-2V6z" />
                  </svg>
                )}
              </span>
              <div>
                <strong>{card.title}</strong>
                <span>{card.desc}</span>
              </div>
            </article>
          </>
        ))
      }
    </div>
  </div>
</section>
